# ─────────────────────────────────────────────
# LLM
# Get from: console.groq.com → API Keys → Create API Key (free)
# ─────────────────────────────────────────────
GROQ_API_KEY=your_key_here

# ─────────────────────────────────────────────
# Stock Video
# Pexels: pexels.com/api → sign in → your key is on the dashboard (free)
# Pixabay: pixabay.com/api/docs → sign in → key shown at top (free, optional)
# ─────────────────────────────────────────────
PEXELS_API_KEY=your_key_here
PIXABAY_API_KEY=your_key_here

# ─────────────────────────────────────────────
# Twitter / Nitter — NO CREDENTIALS NEEDED
# twitter_scraper.py uses free public Nitter RSS mirrors.
# Nitter is an open-source Twitter frontend — no API key, no account, no approval.
# No action needed here. It works out of the box.
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# YouTube Upload
# 1. Go to console.cloud.google.com
# 2. Create project → Enable "YouTube Data API v3"
# 3. Credentials → Create → OAuth 2.0 Client ID → Desktop App
# 4. Download JSON → rename to client_secrets.json → place in project root
# 5. Copy client_id and client_secret below
# First run will open browser for one-time auth → saves token.json automatically
# ─────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your_id
YOUTUBE_CLIENT_SECRET=your_secret

# ─────────────────────────────────────────────
# Facebook Upload
# 1. developers.facebook.com → Create App → Business
# 2. Add "Pages API" product
# 3. Graph API Explorer → select app → generate Page Access Token
# 4. Page ID: found in your Facebook Page settings → About
# ─────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=token_here
FACEBOOK_PAGE_ID=your_page_id

# ─────────────────────────────────────────────
# Instagram Upload
# 1. Instagram account must be Professional (Creator or Business)
# 2. Link it to a Facebook Page
# 3. In same Facebook app above → add "Instagram Graph API" product
# 4. Graph API Explorer → get token with permissions:
#    instagram_basic, instagram_content_publish
# 5. Call GET /me?fields=id with that token → copy the id as INSTAGRAM_USER_ID
# Note: Instagram requires video to be at a public HTTPS URL before uploading
# ─────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=token_here
INSTAGRAM_USER_ID=your_ig_user_id

# ─────────────────────────────────────────────
# Piper TTS (Offline Voice)
# 1. Download binary: github.com/rhasspy/piper/releases → pick your OS
# 2. Extract → place piper.exe (Windows) or piper (Linux/Mac) in project root
#    OR add its folder to your system PATH
# 3. Download model: huggingface.co/rhasspy/piper-voices
#    → en/en_US/lessac/medium → download both .onnx and .onnx.json files
# 4. Place both files in: auto-video-factory/models/
# ─────────────────────────────────────────────
PIPER_EXECUTABLE=piper
PIPER_MODEL=en_US-lessac-medium
PIPER_MODEL_PATH=./models/en_US-lessac-medium.onnx

# ─────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────
LOG_LEVEL=INFO