{
  "name": "auto-video-factory",
  "version": "1.0.0",
  "description": "AI-powered automated short video creation desktop app",
  "main": "frontend/electron/main.js",
  "scripts": {
    "dev:vite": "vite --config frontend/vite.config.js --host --open",
    "dev:electron": "wait-on http://localhost:5173 && electron frontend/electron/main.js",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build --config frontend/vite.config.js",
    "preview": "vite preview --config frontend/vite.config.js",
    "backend": "cd backend && uvicorn main:app --reload --port 8000"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^41.1.0",
    "vite": "^5.2.10",
    "wait-on": "^7.2.0"
  }
}
